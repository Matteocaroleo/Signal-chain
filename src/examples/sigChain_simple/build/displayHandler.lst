 221:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****     void SoftSpiTransmit(uint8_t val)
 222:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****     {
 223:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         // bit flip
 224:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         val = ((val & 0x01) << 7) | ((val & 0x02) << 5) | ((val & 0x04) << 3)
 225:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****               | ((val & 0x08) << 1) | ((val & 0x10) >> 1) | ((val & 0x20) >> 3)
 226:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****               | ((val & 0x40) >> 5) | ((val & 0x80) >> 7);
 227:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h **** 
 228:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         for(uint8_t bit = 0u; bit < 8u; bit++)
 229:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         {
 230:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             pin_mosi_.Write((val & (1 << bit)) ? 1 : 0);
 231:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h **** 
 232:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             System::DelayTicks(clk_delay);
 233:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h **** 
 234:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             pin_sclk_.Toggle();
 235:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h **** 
 236:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             System::DelayTicks(clk_delay);
 237:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h **** 
 238:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****             pin_sclk_.Toggle();
 239:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****         }
 240:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/dev/oled_ssd130x.h ****     }
