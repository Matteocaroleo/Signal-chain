   8:../../../libs/libDaisy/src/per/sai.h **** namespace daisy
   9:../../../libs/libDaisy/src/per/sai.h **** {
  10:../../../libs/libDaisy/src/per/sai.h **** /** 
  11:../../../libs/libDaisy/src/per/sai.h ****  * Support for I2S Audio Protocol with different bit-depth, samplerate options
  12:../../../libs/libDaisy/src/per/sai.h ****  * Allows for master or slave, as well as freedom of selecting direction, 
  13:../../../libs/libDaisy/src/per/sai.h ****  * and other behavior for each peripheral, and block.
  14:../../../libs/libDaisy/src/per/sai.h ****  * 
  15:../../../libs/libDaisy/src/per/sai.h ****  * DMA Transfer commands must use buffers located within non-cached memory or use cache maintenance
  16:../../../libs/libDaisy/src/per/sai.h ****  * To declare an unitialized global element in the DMA memory section:
  17:../../../libs/libDaisy/src/per/sai.h ****  *    int32_t DSY_DMA_BUFFER_SECTOR my_buffer[96];
  18:../../../libs/libDaisy/src/per/sai.h ****  *
  19:../../../libs/libDaisy/src/per/sai.h ****  * Callback functions will be called once per half of the buffer. In the above example, 
  20:../../../libs/libDaisy/src/per/sai.h ****  * the callback function would be called once for every 48 samples.
  21:../../../libs/libDaisy/src/per/sai.h ****  * 
  22:../../../libs/libDaisy/src/per/sai.h ****  * Use SAI Handle like this:
  23:../../../libs/libDaisy/src/per/sai.h ****  * 
  24:../../../libs/libDaisy/src/per/sai.h ****  *  SaiHandle::Config sai_config;
  25:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.periph          = SaiHandle::Config::Peripheral::SAI_1;
  26:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.sr              = SaiHandle::Config::SampleRate::SAI_48KHZ;
  27:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.bit_depth       = SaiHandle::Config::BitDepth::SAI_24BIT;
  28:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.a_sync          = SaiHandle::Config::Sync::MASTER;
  29:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.b_sync          = SaiHandle::Config::Sync::SLAVE;
  30:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.a_dir           = SaiHandle::Config::Direction::RECEIVE;
  31:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.b_dir           = SaiHandle::Config::Direction::TRANSMIT;
  32:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.fs   = {DSY_GPIOE, 4};
  33:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.mclk = {DSY_GPIOE, 2};
  34:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sck  = {DSY_GPIOE, 5};
  35:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sa   = {DSY_GPIOE, 6};
  36:../../../libs/libDaisy/src/per/sai.h ****  *  sai_config.pin_config.sb   = {DSY_GPIOE, 3};
  37:../../../libs/libDaisy/src/per/sai.h ****  *  // Then Initialize
  38:../../../libs/libDaisy/src/per/sai.h ****  *  SaiHandle sai;
  39:../../../libs/libDaisy/src/per/sai.h ****  *  sai.Init(sai_config);
  40:../../../libs/libDaisy/src/per/sai.h ****  *  // Now you can use it:
  41:../../../libs/libDaisy/src/per/sai.h ****  *  sai.StartDma(. . .);
  42:../../../libs/libDaisy/src/per/sai.h ****  */
ARM GAS  C:\Users\matte\AppData\Local\Temp\ccvxIdCr.s 			page 220


