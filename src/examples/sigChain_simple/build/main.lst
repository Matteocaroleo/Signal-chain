  53:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****      ** The output range will be: 0V - VDDA
  54:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****      ** The resolution will be roughly: bitdepth / (VDDA - 0V) 
  55:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****      ***/
  56:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****     enum class BitDepth
