 173:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/hid/disp/display.h ****         currentX_ = (x >= Width()) ? Width() - 1 : x;
 174:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/hid/disp/display.h ****         currentY_ = (y >= Height()) ? Height() - 1 : y;
