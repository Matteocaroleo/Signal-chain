  26:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****     {
  27:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****         OK,
  28:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****         ERR,
  29:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****     };
  30:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h **** 
  31:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****     /** Selects which channel(s) will be configured for use. */
  32:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****     enum class Channel
