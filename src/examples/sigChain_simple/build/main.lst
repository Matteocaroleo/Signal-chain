   8:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h **** {
   9:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h **** /** @brief DAC handle for Built-in DAC Peripheral 
  10:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  *  @ingroup per_analog
  11:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** 
  12:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** For now only Normal Mode is supported,
  13:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** Sample and hold mode provides reduced power consumption, but requires a bit more setup.
  14:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  **
  15:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** For now connecting the DAC through other internal peripherals is also not supported.
  16:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  **
  17:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** Since the DAC channels have dedicated pins we don't need to pass in a pin config like with
  18:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** other modules. However, it is still important to not try to use the DAC pins for anything else.
  19:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ** DAC Channel 1 is on PA4, and DAC Channel 2 is on PA5
  20:../../../libs/libDaisy/src/sys/../../../../libs/libDaisy/src/per/dac.h ****  ***/
